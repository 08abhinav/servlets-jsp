	</servlet>
	<servlet-mapping>
		<servlet-name>Practice1</servlet-name>
		<url-pattern>/practice</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>Practice2</servlet-name>
		<servlet-class>com.Abhinav.InterviewPractice.Practice2</servlet-class>
